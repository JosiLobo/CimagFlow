generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  GESTOR
  COLABORADOR
}

enum DocumentStatus {
  RASCUNHO
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

enum SignerStatus {
  PENDENTE
  ASSINADO
  RECUSADO
}

enum SignerType {
  FORNECEDOR
  PREFEITO
  PRESIDENTE
  JURIDICO
  TESTEMUNHA
  OUTRO
}

enum BidType {
  CHAMADA_PUBLICA
  COMPRA_DIRETA
  CONCORRENCIA
  CONCURSO
  CONVENIO
  CONVITE
  CREDENCIAMENTO
  DISPENSA
  INEXIGIBILIDADE
  LEILAO
  PREGAO
  PREGAO_ELETRONICO
  RATEIO
  TOMADA_PRECOS
}

enum BidStatus {
  ABERTO
  EM_ANDAMENTO
  ENCERRADO
  CANCELADO
  SUSPENSO
}

enum DemandStatus {
  ABERTA
  EM_ANALISE
  EM_ANDAMENTO
  AGUARDANDO_RESPOSTA
  CONCLUIDA
  CANCELADA
}

enum DemandPriority {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

model User {
  id          String     @id @default(cuid())
  name        String
  email       String     @unique
  password    String
  role        Role       @default(COLABORADOR)
  phone       String?
  photo       String?
  isActive    Boolean    @default(true)
  permissions String[]   @default([])
  lastLoginAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  documents   Document[]
  templates   Template[]
  notifications Notification[]
  folders     Folder[]
  bids        Bid[]
  auditLogs   AuditLog[]
  demandsCreated     Demand[] @relation("DemandCreator")
  demandsAssigned    Demand[] @relation("DemandAssigned")
  minutesCreated     MinutesOfMeeting[] @relation("MinuteCreator")
  minutesApproved    MinutesOfMeeting[] @relation("MinuteApprover")
  adhesionReviews    MinuteAdhesion[]
  credenciamentosAssigned Credenciamento[] @relation("CredenciamentoAssigned")
  credenciamentosReviewed Credenciamento[] @relation("CredenciamentoReviewer")
  credenciamentoMessages  CredenciamentoMessage[]

  @@map("users")
}

model Document {
  id          String         @id @default(cuid())
  title       String
  description String?
  content     String?        @db.Text
  fileUrl     String?
  fileName    String?
  fileSize    Int?
  status      DocumentStatus @default(RASCUNHO)
  deadline    DateTime?
  message     String?
  reminderDays Int?          @default(3)
  folderId    String?
  bidId       String?
  templateId  String?
  demandId    String?
  companyId   String?
  createdBy   String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  creator     User           @relation(fields: [createdBy], references: [id])
  folder      Folder?        @relation(fields: [folderId], references: [id])
  bid         Bid?           @relation(fields: [bidId], references: [id])
  template    Template?      @relation(fields: [templateId], references: [id])
  demand      Demand?        @relation(fields: [demandId], references: [id])
  company     Company?       @relation(fields: [companyId], references: [id])
  signers     DocumentSigner[]
  items       DocumentItem[]

  @@index([createdBy])
  @@index([status])
  @@index([folderId])
  @@index([companyId])
  @@index([createdAt])
  @@map("documents")
}

model Template {
  id          String   @id @default(cuid())
  name        String
  description String?
  content     String   @db.Text
  variables   String[] @default([])
  headerImage String?  @db.Text
  footerImage String?  @db.Text
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator     User       @relation(fields: [createdBy], references: [id])
  documents   Document[]

  @@index([createdBy])
  @@map("templates")
}

model Signer {
  id           String     @id @default(cuid())
  name         String
  email        String
  phone        String?
  cpf          String?
  type         SignerType @default(OUTRO)
  municipality String?
  company      String?
  prefectureId String?
  companyId    String?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  prefecture   Prefecture? @relation(fields: [prefectureId], references: [id])
  companyRef   Company?    @relation(fields: [companyId], references: [id])
  documentSigners DocumentSigner[]

  @@index([email])
  @@map("signers")
}

model DocumentSigner {
  id             String       @id @default(cuid())
  documentId     String
  signerId       String
  status         SignerStatus @default(PENDENTE)
  signedAt       DateTime?
  token          String       @unique @default(cuid())
  tokenUsedAt    DateTime?
  order          Int          @default(0)
  ipAddress      String?
  cpfUsed        String?
  signatureImage String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  document    Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signer      Signer       @relation(fields: [signerId], references: [id])

  @@index([documentId])
  @@index([signerId])
  @@index([status])
  @@map("document_signers")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@map("notifications")
}

model Folder {
  id           String   @id @default(cuid())
  name         String
  description  String?
  parentId     String?
  prefectureId String?
  createdBy    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  parent       Folder?     @relation("FolderHierarchy", fields: [parentId], references: [id])
  children     Folder[]    @relation("FolderHierarchy")
  creator      User        @relation(fields: [createdBy], references: [id])
  prefecture   Prefecture? @relation(fields: [prefectureId], references: [id])
  documents    Document[]

  @@index([createdBy])
  @@index([parentId])
  @@map("folders")
}

model Prefecture {
  id          String   @id @default(cuid())
  name        String
  cnpj        String?
  address     String?
  city        String
  state       String
  phone       String?
  email       String?
  mayorName   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  signers     Signer[]
  demands     Demand[]
  bids        Bid[]
  folders     Folder[]
  minutes     MinutesOfMeeting[]
  credenciamentos Credenciamento[]

  @@map("prefectures")
}

model Company {
  id            String   @id @default(cuid())
  name          String
  tradeName     String?
  cnpj          String?
  address       String?
  number        String?
  complement    String?
  cep           String?
  city          String?
  state         String?
  phone         String?
  email         String?
  contactName   String?
  isCredenciada Boolean  @default(false)
  bidId         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bid           Bid?     @relation(fields: [bidId], references: [id])
  signers       Signer[]
  items         CompanyItem[]
  documents     Document[]

  @@index([bidId])
  @@map("companies")
}

model CompanyItem {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?
  unit        String   @default("UN")
  quantity    Float    @default(1)
  unitPrice   Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("company_items")
}

model DocumentItem {
  id          String   @id @default(cuid())
  documentId  String
  name        String
  description String?
  unit        String   @default("UN")
  quantity    Float    @default(1)
  unitPrice   Float    @default(0)
  createdAt   DateTime @default(now())

  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_items")
}

model Bid {
  id           String    @id @default(cuid())
  number       String
  title        String
  description  String?   @db.Text
  type         BidType   @default(PREGAO_ELETRONICO)
  status       BidStatus @default(ABERTO)
  openingDate  DateTime?
  closingDate  DateTime?
  value        Float?
  fileUrl      String?
  fileName     String?
  fileSize     Int?
  prefectureId String?
  createdBy    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  prefecture   Prefecture? @relation(fields: [prefectureId], references: [id])
  creator      User        @relation(fields: [createdBy], references: [id])
  documents    Document[]
  companies    Company[]
  minutes      MinutesOfMeeting[]

  @@index([createdBy])
  @@index([status])
  @@map("bids")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  SIGN
  REFUSE
  SEND
  CANCEL
  LOGIN
  LOGOUT
}

model AuditLog {
  id          String      @id @default(cuid())
  userId      String?
  userName    String?
  action      AuditAction
  entity      String
  entityId    String?
  entityName  String?
  details     String?     @db.Text
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}

model Demand {
  id              String         @id @default(cuid())
  protocolNumber  String         @unique
  title           String
  description     String         @db.Text
  status          DemandStatus   @default(ABERTA)
  priority        DemandPriority @default(MEDIA)
  
  // Informações do Requerente
  requesterName   String
  requesterEmail  String
  requesterPhone  String?
  requesterCpf    String?
  dotacao         String?
  
  // Relacionamentos
  prefectureId    String?
  assignedToId    String?
  createdBy       String?
  
  // Flags
  publicSubmission Boolean       @default(false)
  
  // Datas
  dueDate         DateTime?
  resolvedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  // Anexos e observações
  attachments     String[]       @default([])
  responseAttachments String[]   @default([])
  internalNotes   String?        @db.Text
  resolution      String?        @db.Text
  responseComment String?        @db.Text
  
  // Relacionamentos
  prefecture      Prefecture?    @relation(fields: [prefectureId], references: [id])
  assignedTo      User?          @relation("DemandAssigned", fields: [assignedToId], references: [id])
  creator         User?          @relation("DemandCreator", fields: [createdBy], references: [id])
  history         DemandHistory[]
  documents       Document[]
  
  @@index([protocolNumber])
  @@index([status])
  @@index([prefectureId])
  @@index([createdAt])
  @@map("demands")
}

model DemandHistory {
  id          String       @id @default(cuid())
  demandId    String
  userId      String?
  userName    String
  action      String
  oldValue    String?
  newValue    String?
  comment     String?      @db.Text
  createdAt   DateTime     @default(now())
  
  demand      Demand       @relation(fields: [demandId], references: [id], onDelete: Cascade)
  
  @@index([demandId])
  @@index([createdAt])
  @@map("demand_history")
}

enum MinuteStatus {
  RASCUNHO
  APROVADA
  PUBLICADA
  ARQUIVADA
}

enum MinuteType {
  ORDINARIA
  EXTRAORDINARIA
  ESPECIAL
  SOLENE
}

model MinutesOfMeeting {
  id              String        @id @default(cuid())
  number          String        @unique
  title           String
  description     String?       @db.Text
  type            MinuteType    @default(ORDINARIA)
  status          MinuteStatus  @default(RASCUNHO)
  meetingDate     DateTime
  startTime       String?
  endTime         String?
  location        String?
  participants    String[]      @default([])
  content         String?       @db.Text
  decisions       String?       @db.Text
  attachments     String[]      @default([])
  
  // Campos para Ata de Registro de Preço
  isPriceRegistry Boolean       @default(false)
  validityStartDate DateTime?
  validityEndDate   DateTime?
  isPublic        Boolean       @default(false)
  allowAdhesion   Boolean       @default(false)
  priceValue      Float?
  items           String?       @db.Text
  
  prefectureId    String?
  bidId           String?
  createdBy       String
  approvedBy      String?
  approvedAt      DateTime?
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  prefecture      Prefecture?   @relation(fields: [prefectureId], references: [id])
  bid             Bid?          @relation(fields: [bidId], references: [id])
  creator         User          @relation("MinuteCreator", fields: [createdBy], references: [id])
  approver        User?         @relation("MinuteApprover", fields: [approvedBy], references: [id])
  adhesions       MinuteAdhesion[]
  
  @@index([number])
  @@index([status])
  @@index([prefectureId])
  @@index([meetingDate])
  @@index([isPriceRegistry])
  @@index([isPublic])
  @@map("minutes_of_meeting")
}

enum AdhesionStatus {
  PENDENTE
  APROVADA
  REJEITADA
  CANCELADA
}

model MinuteAdhesion {
  id                String         @id @default(cuid())
  minuteId          String
  
  // Dados do solicitante
  requesterName     String
  requesterEmail    String
  requesterPhone    String?
  requesterCpf      String?
  requesterCnpj     String?
  companyName       String?
  position          String?
  
  // Dados da adesão
  status            AdhesionStatus @default(PENDENTE)
  requestDate       DateTime       @default(now())
  justification     String?        @db.Text
  attachments       String[]       @default([])
  
  // Aprovação/Rejeição
  reviewedBy        String?
  reviewedAt        DateTime?
  reviewComment     String?        @db.Text
  
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  
  minute            MinutesOfMeeting @relation(fields: [minuteId], references: [id], onDelete: Cascade)
  reviewer          User?            @relation(fields: [reviewedBy], references: [id])
  
  @@index([minuteId])
  @@index([status])
  @@index([requesterEmail])
  @@map("minute_adhesions")
}

enum CredenciamentoStatus {
  PENDENTE
  EM_ANALISE
  APROVADO
  REPROVADO
  CANCELADO
}

model Credenciamento {
  id                String                @id @default(cuid())
  protocolNumber    String                @unique
  
  // Dados do Solicitante
  requesterName     String
  requesterEmail    String
  requesterPhone    String
  requesterCpf      String
  requesterCnpj     String
  
  // Dados da Empresa
  companyName       String
  tradeName         String?
  fantasyName       String?
  companyAddress    String
  companyCity       String
  companyState      String
  companyCep        String
  companyPhone      String
  companyEmail      String
  
  // Informações do Credenciamento
  title             String
  description       String               @db.Text
  activityArea      String?              // Área de atuação
  requestedServices String?              @db.Text // Serviços solicitados
  
  // Status e Prioridade
  status            CredenciamentoStatus @default(PENDENTE)
  priority          DemandPriority       @default(MEDIA)
  
  // Documentação
  attachments       String[]             @default([])
  documents         String?              @db.Text // JSON com lista de documentos anexados
  documentsApproval String?              @db.Text // JSON com status de aprovação de cada documento: [{url, name, status, reviewedBy, reviewedAt, comment}]
  
  // Prefeitura relacionada
  prefectureId      String?
  
  // Análise e Aprovação
  assignedToId      String?
  reviewerId        String?
  reviewedAt        DateTime?
  analysisNotes     String?              @db.Text // Notas de análise
  rejectionReason   String?              @db.Text // Motivo de reprovação
  approvalDocument  String?              // URL do documento de aprovação
  approvedAt        DateTime?            // Data de aprovação
  rejectedAt        DateTime?            // Data de reprovação
  
  // Flags
  publicSubmission  Boolean              @default(true)
  
  // Datas
  dueDate           DateTime?
  resolvedAt        DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  
  // Relacionamentos
  prefecture        Prefecture?          @relation(fields: [prefectureId], references: [id])
  assignedTo        User?                @relation("CredenciamentoAssigned", fields: [assignedToId], references: [id])
  reviewer          User?                @relation("CredenciamentoReviewer", fields: [reviewerId], references: [id])
  history           CredenciamentoHistory[]
  messages          CredenciamentoMessage[]
  
  @@index([protocolNumber])
  @@index([status])
  @@index([prefectureId])
  @@index([requesterEmail])
  @@index([createdAt])
  @@map("credenciamentos")
}

model CredenciamentoHistory {
  id                String         @id @default(cuid())
  credenciamentoId  String
  userId            String?
  userName          String
  action            String
  oldValue          String?
  newValue          String?
  comment           String?        @db.Text
  createdAt         DateTime       @default(now())
  
  credenciamento    Credenciamento @relation(fields: [credenciamentoId], references: [id], onDelete: Cascade)
  
  @@index([credenciamentoId])
  @@index([createdAt])
  @@map("credenciamento_history")
}

model CredenciamentoMessage {
  id                String         @id @default(cuid())
  credenciamentoId  String
  senderName        String         // Nome do remetente
  senderEmail       String         // Email do remetente
  senderType        String         // "ANALYST" ou "COMPANY"
  userId            String?        // ID do usuário analista (se aplicável)
  message           String         @db.Text
  attachments       String[]       @default([])
  isInternal        Boolean        @default(false) // Se é nota interna (não enviada por email)
  emailSent         Boolean        @default(false) // Se o email foi enviado
  readAt            DateTime?      // Quando foi lido
  createdAt         DateTime       @default(now())
  
  credenciamento    Credenciamento @relation(fields: [credenciamentoId], references: [id], onDelete: Cascade)
  user              User?          @relation(fields: [userId], references: [id])
  
  @@index([credenciamentoId])
  @@index([createdAt])
  @@index([senderType])
  @@map("credenciamento_messages")
}
